# ============================================
# BOSSVIEW — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# IMPORTANT: Never commit the .env file to version control!

# ── General ──────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── Nginx ────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── API ──────────────────────────────────────
API_URL=/api/v1
WS_URL=/ws
CORS_ORIGIN=https://bossview.yourcompany.com

# ── Authentication (REQUIRED — generate with: openssl rand -hex 32) ──
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Encryption (REQUIRED — for connector secrets, generate with: openssl rand -hex 32) ──
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── PostgreSQL ───────────────────────────────
POSTGRES_USER=bossview
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=bossview

# ── Redis ────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ── Connector Engine ────────────────────────
CONNECTOR_POLL_INTERVAL=300  # Sekunden (5 Minuten)

# ── LDAP/AD (Optional) ──────────────────────
# LDAP_URL=ldap://ad.yourcompany.com:389
# LDAP_BASE_DN=dc=yourcompany,dc=com
# LDAP_BIND_DN=cn=bossview-svc,ou=ServiceAccounts,dc=yourcompany,dc=com
# LDAP_BIND_PASSWORD=
# LDAP_USER_SEARCH_BASE=ou=Users,dc=yourcompany,dc=com
# LDAP_GROUP_SEARCH_BASE=ou=Groups,dc=yourcompany,dc=com
