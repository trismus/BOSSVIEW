{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "SKYNEX Design Tokens — Tactical Command aesthetic. W3C Design Tokens Community Group format.",
  "$metadata": {
    "version": "1.0.0",
    "system": "skynex",
    "lastUpdated": "2026-04-09"
  },
  "color": {
    "surface": {
      "base": { "$value": "#0b0e14", "$type": "color", "$description": "Atmosphere — the infinite base" },
      "containerLowest": { "$value": "#000000", "$type": "color", "$description": "Recessed data input areas" },
      "containerLow": { "$value": "#10131a", "$type": "color", "$description": "Secondary sections, sidebars" },
      "container": { "$value": "#161a21", "$type": "color", "$description": "Primary container for data groups" },
      "containerHigh": { "$value": "#1c2028", "$type": "color", "$description": "Hover / active selection" }
    },
    "primary": {
      "base": { "$value": "#99f7ff", "$type": "color", "$description": "High-contrast neon accent, KPIs" },
      "container": { "$value": "#00f1fe", "$type": "color", "$description": "Gradient end-stop, CTA glow" },
      "on": { "$value": "#001f22", "$type": "color", "$description": "Text on primary" }
    },
    "status": {
      "error": { "$value": "#ff716c", "$type": "color", "$description": "Critical alerts, outages" },
      "warning": { "$value": "#ffd16f", "$type": "color", "$description": "Degraded, needs attention" },
      "success": { "$value": "#7cffa8", "$type": "color", "$description": "Healthy, green state" },
      "info": { "$value": "#99f7ff", "$type": "color", "$description": "Neutral info" }
    },
    "text": {
      "onSurface": { "$value": "#e4e6eb", "$type": "color", "$description": "Primary text" },
      "onSurfaceVariant": { "$value": "#9ca3af", "$type": "color", "$description": "Secondary text" },
      "onSurfaceDim": { "$value": "#6b7280", "$type": "color", "$description": "Tertiary / metadata" }
    },
    "outline": {
      "variant": { "$value": "#45484f", "$type": "color", "$description": "Ghost borders (use at 15% opacity)" }
    }
  },
  "gradient": {
    "primary": {
      "$value": "linear-gradient(135deg, #99f7ff 0%, #00f1fe 100%)",
      "$type": "gradient",
      "$description": "Primary CTA gradient — signature glow"
    }
  },
  "font": {
    "family": {
      "display": { "$value": "'Space Grotesk', sans-serif", "$type": "fontFamily", "$description": "Command font for headlines and KPIs" },
      "body": { "$value": "'Inter', -apple-system, 'Helvetica Neue', sans-serif", "$type": "fontFamily", "$description": "Information font" },
      "mono": { "$value": "'JetBrains Mono', 'SF Mono', Consolas, monospace", "$type": "fontFamily", "$description": "Data and technical labels" }
    },
    "weight": {
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "displayLg": { "$value": "57px", "$type": "dimension" },
      "displayMd": { "$value": "45px", "$type": "dimension" },
      "displaySm": { "$value": "36px", "$type": "dimension" },
      "headlineLg": { "$value": "32px", "$type": "dimension" },
      "headlineMd": { "$value": "28px", "$type": "dimension" },
      "headlineSm": { "$value": "24px", "$type": "dimension" },
      "titleLg": { "$value": "22px", "$type": "dimension" },
      "titleMd": { "$value": "16px", "$type": "dimension" },
      "titleSm": { "$value": "14px", "$type": "dimension" },
      "bodyLg": { "$value": "16px", "$type": "dimension" },
      "bodyMd": { "$value": "14px", "$type": "dimension" },
      "bodySm": { "$value": "12px", "$type": "dimension" },
      "labelMd": { "$value": "12px", "$type": "dimension" }
    },
    "lineHeight": {
      "displayLg": { "$value": "64px", "$type": "dimension" },
      "displayMd": { "$value": "52px", "$type": "dimension" },
      "displaySm": { "$value": "44px", "$type": "dimension" },
      "headlineLg": { "$value": "40px", "$type": "dimension" },
      "headlineMd": { "$value": "36px", "$type": "dimension" },
      "headlineSm": { "$value": "32px", "$type": "dimension" },
      "titleLg": { "$value": "28px", "$type": "dimension" },
      "titleMd": { "$value": "24px", "$type": "dimension" },
      "titleSm": { "$value": "20px", "$type": "dimension" },
      "bodyLg": { "$value": "24px", "$type": "dimension" },
      "bodyMd": { "$value": "20px", "$type": "dimension" },
      "bodySm": { "$value": "16px", "$type": "dimension" }
    }
  },
  "space": {
    "0": { "$value": "0", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "20px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0", "$type": "dimension" },
    "xs": { "$value": "2px", "$type": "dimension" },
    "sm": { "$value": "2px", "$type": "dimension", "$description": "0.125rem — cards, tight containers" },
    "md": { "$value": "6px", "$type": "dimension", "$description": "0.375rem — cards, buttons" },
    "lg": { "$value": "10px", "$type": "dimension", "$description": "0.625rem — modals" },
    "xl": { "$value": "12px", "$type": "dimension", "$description": "0.75rem — maximum allowed" }
  },
  "elevation": {
    "sm": {
      "$value": "0px 2px 8px rgba(0, 0, 0, 0.3)",
      "$type": "shadow"
    },
    "md": {
      "$value": "0px 6px 16px rgba(0, 0, 0, 0.35)",
      "$type": "shadow"
    },
    "lg": {
      "$value": "0px 12px 32px rgba(0, 0, 0, 0.4)",
      "$type": "shadow"
    },
    "xl": {
      "$value": "0px 24px 48px rgba(0, 0, 0, 0.45)",
      "$type": "shadow"
    }
  },
  "glow": {
    "primary": {
      "$value": "0 0 16px rgba(0, 241, 254, 0.4)",
      "$type": "shadow",
      "$description": "Primary neon glow for active elements"
    },
    "error": {
      "$value": "0 0 12px rgba(255, 113, 108, 0.3)",
      "$type": "shadow",
      "$description": "Critical status badge glow"
    },
    "warning": {
      "$value": "0 0 12px rgba(255, 209, 111, 0.3)",
      "$type": "shadow"
    },
    "success": {
      "$value": "0 0 12px rgba(124, 255, 168, 0.3)",
      "$type": "shadow"
    }
  },
  "blur": {
    "glass": { "$value": "20px", "$type": "dimension", "$description": "Glassmorphism backdrop-blur" }
  },
  "opacity": {
    "ghostBorder": { "$value": 0.15, "$type": "number", "$description": "Ghost border opacity for outline-variant" },
    "glassSurface": { "$value": 0.6, "$type": "number", "$description": "Glassmorphism surface opacity" }
  }
}
